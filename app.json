{
  "expo": {
    "name": "カララボ",
    "slug": "fitness_app",
    "version": "1.0.0",
    "description": "AIコーチと共感する、次世代の食生活研究室。",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fitnessapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.colorlab.fitness",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.colorlab.fitness",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "食品のバーコードやパッケージをスキャンして解析するために、カメラへのアクセスを許可してください。"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "食事の画像を解析するために、写真ライブラリへのアクセスを許可してください。"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "4c5319f4-a7a8-460c-957d-8abf83237296"
      }
    }
  }
}