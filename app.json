{
  "expo": {
    "name": "カララボ",
    "slug": "fitness_app",
    "version": "1.1.1",
    "description": "AIコーチと共感する、次世代の食生活研究室。",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fitnessapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.colorlab.fitness",
      "buildNumber": "5",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserTrackingUsageDescription": "個別にカスタマイズされた広告を表示するために、トラッキングの許可をお願いします。",
        "GADApplicationIdentifier": "ca-app-pub-3940256099942544~1458002511"
      }
    },
    "android": {
      "package": "com.colorlab.fitness",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "食品のバーコードやパッケージをスキャンして解析するために、カメラへのアクセスを許可してください。"
        }
      ],
      [
        "react-native-iap",
        {}
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "個別にカスタマイズされた広告を表示するために、トラッキングの許可をお願いします。"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "4c5319f4-a7a8-460c-957d-8abf83237296"
      }
    }
  }
}
