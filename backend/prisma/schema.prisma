generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model FoodProduct {
  barcode   String    @id
  name      String
  calories  Float
  protein   Float
  fat       Float
  carbs     Float
  source    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  mealLogs  MealLog[]
}

model MealLog {
  id          Int         @id @default(autoincrement())
  userId      String
  foodId      String
  quantity    Float
  mealType    String
  date        DateTime    @default(now())
  foodProduct FoodProduct @relation(fields: [foodId], references: [barcode])
}

model AiAnalysisCache {
  imageHash  String   @id
  resultJson String
  createdAt  DateTime @default(now())
}
